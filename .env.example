# AnyClaw .env example
#
# Copy this file to `.env` and fill in your values.

# -----------------------------------------------------------------------------
# LLM Provider API Keys (set at least one)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# -----------------------------------------------------------------------------
# Local Ollama (optional)
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
